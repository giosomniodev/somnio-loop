# Plugin build artifacts
*.plugin
dist/
build/

# Run-time state (created by the plugin in any consumer project — never in the plugin source itself)
.loop/traces/
.loop/plans/

# Allow .loop/state.md, .loop/run-log.md, .loop/config.yaml, .loop/budget.md if a team wants to commit them
# (uncomment to ignore them too)
# .loop/state.md
# .loop/run-log.md

# Tooling
.DS_Store
*.swp
*.swo
.idea/
.vscode/
*.code-workspace
.cursor/
.windsurf/

# Test scratch
/tmp/
scratch/
.test-output/

# Node (in case anyone adds tooling that uses it)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python (in case anyone adds tooling that uses it)
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/

# Old artifacts from previous sessions (Cowork outputs leak-through)
run-report.md
loop-runs/
